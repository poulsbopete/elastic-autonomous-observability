#!/bin/bash
# Minimal load generator: starts collector and optionally emits sample OTLP data.
# Usage: ./load-generator start | stop | emit-log | emit-metric | emit-trace
# Assumes Docker and env ELASTIC_ENDPOINT, ELASTIC_API_KEY. Config at /workshop/otel-config.yaml or /tmp/otel-config.yaml.

set -euo pipefail
CONFIG="${OTEL_CONFIG:-/tmp/otel-config.yaml}"

start() {
  [ -f "$CONFIG" ] || { echo "Config not found: $CONFIG"; return 1; }
  docker run -d --name otelcol \
    -p 4317:4317 -p 4318:4318 \
    -v "$CONFIG:/etc/otelcol/config.yaml:ro" \
    -e ELASTIC_ENDPOINT -e ELASTIC_API_KEY \
    otel/opentelemetry-collector-contrib:latest \
    --config /etc/otelcol/config.yaml 2>/dev/null || true
  # Optional: start demo app that sends OTLP
  docker run -d --name demo-app --link otelcol:otelcol \
    -e OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4318 \
    your-registry/demo-app:latest 2>/dev/null || true
  echo "Collector (and optional demo-app) started."
}

stop() {
  docker stop demo-app otelcol 2>/dev/null || true
  docker rm -f demo-app otelcol 2>/dev/null || true
  echo "Stopped."
}

# Emit one log via OTLP HTTP (requires curl and a collector on 4318)
emit-log() {
  local body='{"resourceLogs":[{"resource":{},"scopeLogs":[{"scope":{},"logRecords":[{"timeUnixNano":"'"$(date +%s)000000000"'","body":{"stringValue":"workshop-log from load-generator"},"attributes":[{"key":"service.name","value":{"stringValue":"load-generator"}}]}]}]}]}'
  curl -s -X POST http://localhost:4318/v1/logs \
    -H "Content-Type: application/json" \
    -d "$body" && echo "Log emitted."
}

# Emit one metric via OTLP HTTP
emit-metric() {
  local now=$(date +%s)
  local body='{"resourceMetrics":[{"resource":{"attributes":[{"key":"service.name","value":{"stringValue":"load-generator"}}]},"scopeMetrics":[{"scope":{},"metrics":[{"name":"workshop_requests_total","sum":{"dataPoints":[{"startTimeUnixNano":"'"${now}"'000000000","timeUnixNano":"'"${now}"'000000000","asInt":"1"}],"aggregationTemporality":2}}]}]}]}'
  curl -s -X POST http://localhost:4318/v1/metrics \
    -H "Content-Type: application/json" \
    -d "$body" && echo "Metric emitted."
}

# Emit one trace (single span) via OTLP HTTP
emit-trace() {
  local id=$(od -A n -t x8 -N 16 /dev/urandom | tr -d ' ')
  local body='{"resourceSpans":[{"resource":{"attributes":[{"key":"service.name","value":{"stringValue":"load-generator"}}]},"scopeSpans":[{"scope":{},"spans":[{"traceId":"'"$id"'","spanId":"'"$(od -A n -t x8 -N 8 /dev/urandom | tr -d ' ')"'","name":"workshop-span","startTimeUnixNano":"'"$(date +%s)000000000"'","endTimeUnixNano":"'"$(date +%s)000000000"'","attributes":[{"key":"http.method","value":{"stringValue":"GET"}}]}]}]}]}'
  curl -s -X POST http://localhost:4318/v1/traces \
    -H "Content-Type: application/json" \
    -d "$body" && echo "Trace emitted. traceId=$id"
}

case "${1:-}" in
  start)  start ;;
  stop)   stop ;;
  emit-log)   emit-log ;;
  emit-metric) emit-metric ;;
  emit-trace)  emit-trace ;;
  *) echo "Usage: $0 start|stop|emit-log|emit-metric|emit-trace"; exit 1 ;;
esac
