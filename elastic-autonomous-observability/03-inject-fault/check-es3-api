#!/usr/bin/env bash
# Challenge 3 check: verify at least one Kibana case was auto-created by the workflow.

APP="http://localhost:8090"
KIBANA="http://localhost:8080"

# ── App healthy ───────────────────────────────────────────────────────────────
if ! curl -sf "${APP}/health" >/dev/null 2>&1; then
  echo "FAIL: Demo app is not responding on port 8090."
  exit 1
fi

# ── At least one deployment exists ───────────────────────────────────────────
DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null)" || DEPS="[]"
DEP_COUNT="$(echo "$DEPS" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len([x for x in d if x.get('running')]))" 2>/dev/null)" || DEP_COUNT="0"

if [[ "$DEP_COUNT" == "0" ]]; then
  echo "FAIL: No active deployment found. Make sure the Fanatics scenario launched in Challenge 1."
  exit 1
fi

# ── At least one Kibana case exists ──────────────────────────────────────────
# Cases are created automatically by the workflow after the AI agent completes RCA.
CASES_RESPONSE="$(curl -sf -o /tmp/cases_check.json -w "%{http_code}" \
  "${KIBANA}/api/cases?perPage=10&sortField=createdAt&sortOrder=desc" \
  -H 'kbn-xsrf: true' 2>/dev/null)" || CASES_RESPONSE="000"

if [[ "$CASES_RESPONSE" != "200" ]]; then
  echo "FAIL: Could not reach Kibana Cases API (HTTP ${CASES_RESPONSE}). Make sure Elastic Serverless is accessible."
  exit 1
fi

CASE_COUNT="$(python3 -c "
import sys, json
try:
    data = json.load(open('/tmp/cases_check.json'))
    # API returns either {cases: [...], total: N} or a list directly
    if isinstance(data, list):
        print(len(data))
    elif isinstance(data, dict):
        print(data.get('total', len(data.get('cases', []))))
    else:
        print(0)
except Exception as e:
    print(0)
" 2>/dev/null)" || CASE_COUNT="0"

if [[ "$CASE_COUNT" == "0" ]]; then
  echo "FAIL: No cases found yet. Inject a fault from the Demo App, wait ~2 minutes for the workflow to complete, then check Observability → Cases."
  exit 1
fi

echo "PASS: ${CASE_COUNT} case(s) found — the workflow ran and the AI agent created a case. Ready to continue!"
exit 0
