#!/usr/bin/env bash
# Challenge 3 check: verify at least one Kibana case was auto-created.
# The AI agent resolves faults automatically, so we cannot rely on active chaos state.

APP="http://localhost:8090"
RESULTS_FILE="/tmp/project_results.json"

# ── App healthy ───────────────────────────────────────────────────────────────
if ! curl -sf "${APP}/health" >/dev/null 2>&1; then
  echo "FAIL: Demo app is not responding on port 8090."
  exit 1
fi

# ── At least one deployment exists ───────────────────────────────────────────
DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null)" || DEPS="[]"
DEP_COUNT="$(echo "$DEPS" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(len([x for x in d if x.get('running')]))
except:
    print(0)
" 2>/dev/null)" || DEP_COUNT="0"

if [[ "${DEP_COUNT:-0}" == "0" ]]; then
  echo "FAIL: No active deployment found. Make sure the Fanatics scenario launched in Challenge 1."
  exit 1
fi

# ── Get credentials from project results file ─────────────────────────────────
if [[ ! -f "$RESULTS_FILE" ]]; then
  echo "FAIL: Project results file not found at $RESULTS_FILE"
  exit 1
fi

REGIONS="${REGIONS:-aws-us-east-1}"
ES_URL="$(python3 -c "import json; d=json.load(open('$RESULTS_FILE')); print(list(d.values())[0]['endpoints']['elasticsearch'])" 2>/dev/null)"
ES_PASS="$(python3 -c "import json; d=json.load(open('$RESULTS_FILE')); print(list(d.values())[0]['credentials']['password'])" 2>/dev/null)"

# ── Query Elasticsearch for cases ────────────────────────────────────────────
if [[ -n "$ES_URL" && -n "$ES_PASS" ]]; then
  CASE_COUNT="$(curl -sf \
    "${ES_URL}/.kibana_cases*/_count" \
    -u "admin:${ES_PASS}" \
    -H 'Content-Type: application/json' \
    -d '{"query":{"match_all":{}}}' 2>/dev/null \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('count',0))" 2>/dev/null)" || CASE_COUNT="0"

  if [[ "${CASE_COUNT:-0}" -gt 0 ]] 2>/dev/null; then
    echo "PASS: ${CASE_COUNT} case record(s) found in Elasticsearch — the workflow ran and the AI agent created a case!"
    exit 0
  fi

  # Try alternate index name
  CASE_COUNT="$(curl -sf \
    "${ES_URL}/.cases*/_count" \
    -u "admin:${ES_PASS}" \
    -H 'Content-Type: application/json' \
    -d '{"query":{"match_all":{}}}' 2>/dev/null \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('count',0))" 2>/dev/null)" || CASE_COUNT="0"

  if [[ "${CASE_COUNT:-0}" -gt 0 ]] 2>/dev/null; then
    echo "PASS: ${CASE_COUNT} case record(s) found — the workflow ran and the AI agent created a case!"
    exit 0
  fi
fi

# ── Fallback: check Kibana Cases API via nginx proxy ─────────────────────────
CASE_COUNT="$(curl -sf --max-time 15 \
  "http://localhost:8080/api/cases/_find?perPage=1" \
  -H 'kbn-xsrf: true' 2>/dev/null \
  | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('total',0))" 2>/dev/null)" || CASE_COUNT="0"

if [[ "${CASE_COUNT:-0}" -gt 0 ]] 2>/dev/null; then
  echo "PASS: ${CASE_COUNT} case(s) found via Kibana API — the workflow ran and the AI agent created a case!"
  exit 0
fi

echo "FAIL: No cases found yet. Inject a fault from the Demo App → Chaos link, wait ~2 minutes for the AI agent to investigate, then check Observability → Cases."
exit 1
