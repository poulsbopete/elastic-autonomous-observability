#!/usr/bin/env bash
# Challenge 3 check: verify the demo app is running and a fault was injected.

APP="http://localhost:8090"

# ── App healthy ───────────────────────────────────────────────────────────────
if ! curl -sf "${APP}/health" >/dev/null 2>&1; then
  echo "FAIL: Demo app is not responding on port 8090."
  exit 1
fi

# ── At least one deployment exists ───────────────────────────────────────────
DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null)" || DEPS="[]"
DEP_COUNT="$(echo "$DEPS" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(len([x for x in d if x.get('running')]))
except:
    print(0)
" 2>/dev/null)" || DEP_COUNT="0"

if [[ "${DEP_COUNT:-0}" == "0" ]]; then
  echo "FAIL: No active deployment found. Make sure the Fanatics scenario launched in Challenge 1."
  exit 1
fi

# ── At least one fault was injected (active OR previously resolved) ───────────
DEP_ID="$(echo "$DEPS" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d[0].get('deployment_id', '') if d else '')
except:
    print('')
" 2>/dev/null)" || DEP_ID=""

CHAOS_URL="${APP}/api/chaos/status"
[[ -n "$DEP_ID" ]] && CHAOS_URL="${APP}/api/chaos/status?deployment_id=${DEP_ID}"
CHAOS="$(curl -sf "$CHAOS_URL" 2>/dev/null)" || CHAOS="{}"

ANY_TRIGGERED="$(echo "$CHAOS" | python3 -c "
import sys, json
try:
    ch = json.load(sys.stdin)
    # Accept any channel that was ever triggered
    found = [k for k,v in ch.items() if isinstance(v, dict) and v.get('state','') not in ('', 'STANDBY', 'INACTIVE')]
    print(len(found))
except:
    print(0)
" 2>/dev/null)" || ANY_TRIGGERED="0"

if [[ "${ANY_TRIGGERED:-0}" -gt 0 ]]; then
  echo "PASS: Fault injected and detected. Check Observability → Cases and Workflows to see the AI agent's response."
  exit 0
fi

echo "FAIL: No fault channels have been triggered yet. Open the Demo App tab, click the Chaos link next to your deployment, and inject any fault channel."
exit 1
