#!/usr/bin/env bash
# Challenge 4 check: verify all fault channels are resolved (no active chaos).

APP="http://localhost:8090"

# ── App healthy ───────────────────────────────────────────────────────────────
if ! curl -sf "${APP}/health" >/dev/null 2>&1; then
  echo "FAIL: Demo app is not responding on port 8090."
  exit 1
fi

# ── At least one deployment exists ───────────────────────────────────────────
DEPS="$(curl -sf "${APP}/api/deployments" 2>/dev/null)" || DEPS="[]"
DEP_COUNT="$(echo "$DEPS" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len([x for x in d if x.get('running')]))" 2>/dev/null)" || DEP_COUNT="0"

if [[ "$DEP_COUNT" == "0" ]]; then
  echo "FAIL: No active deployment found. Complete Challenge 1 first."
  exit 1
fi

# ── No fault channels are active ───────────────────────────────────────────
DEP_ID="$(echo "$DEPS" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0].get('deployment_id','') if d else '')" 2>/dev/null)" || DEP_ID=""

if [[ -n "$DEP_ID" ]]; then
  CHAOS="$(curl -sf "${APP}/api/chaos/status?deployment_id=${DEP_ID}" 2>/dev/null)" || CHAOS="{}"
else
  CHAOS="$(curl -sf "${APP}/api/chaos/status" 2>/dev/null)" || CHAOS="{}"
fi

ACTIVE_COUNT="$(echo "$CHAOS" | python3 -c "
import sys, json
try:
    ch = json.load(sys.stdin)
    active = [k for k,v in ch.items() if isinstance(v,dict) and v.get('state') == 'ACTIVE']
    print(len(active))
except Exception:
    print(0)
" 2>/dev/null)" || ACTIVE_COUNT="0"

if [[ "$ACTIVE_COUNT" != "0" ]]; then
  echo "FAIL: ${ACTIVE_COUNT} fault channel(s) still active. The workflow should resolve them within 2-3 minutes of the alert firing. Or open Demo App -> Chaos link and click RESOLVE on each active channel."
  exit 1
fi

echo "PASS: All fault channels resolved — autonomous remediation loop complete."
exit 0
